{
  "name": "aglaea",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "paraglide:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide --silent",
    "prepare": "svelte-kit sync || echo ''",
    "check": "bun run paraglide:compile && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "bun run paraglide:compile && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "typecheck": "bun run paraglide:compile && tsgo --noEmit",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^9.39.4",
    "@inlang/paraglide-js": "^2.20.0",
    "@internationalized/date": "^3.12.2",
    "@lucide/svelte": "^1.21.0",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-svelte-csf": "^5.1.2",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/sveltekit": "^10.4.6",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/adapter-cloudflare": "^7.2.9",
    "@sveltejs/kit": "^2.66.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^26.0.0",
    "@typescript/native-preview": "^7.0.0-dev.20260619.1",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-storybook": "^10.4.6",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^17.6.0",
    "lefthook": "^2.1.9",
    "playwright": "^1.61.0",
    "prettier": "^3.8.4",
    "prettier-plugin-svelte": "^4.1.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "storybook": "^10.4.6",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "wrangler": "^4.103.0"
  },
  "dependencies": {
    "@aglaea/contract": "^0.4.0",
    "@sinclair/typebox": "^0.34.49",
    "@tanstack/ai": "^0.32.0",
    "@tanstack/svelte-virtual": "^3.13.29",
    "svelte-streamdown": "^3.1.1",
    "zod": "^4.4.3"
  }
}
